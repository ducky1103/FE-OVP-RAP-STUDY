{
  "_version": "1.48.0",
  "sap.app": {
    "id": "zpodashboard",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:ovp",
      "version": "1.20.1",
      "toolsId": "f762b47b-5321-4f9c-987e-382423725159"
    },
    "dataSources": {
      "ZUI_126_DASHBOARD_BINDING_VAN": {
        "uri": "/sap/opu/odata/IWFND/CATALOGSERVICE;v=2/Annotations(TechnicalName='ZUI_126_DASHBOARD_BINDING_VAN',Version='0001')/$value/",
        "type": "ODataAnnotation",
        "settings": {
          "localUri": "localService/mainService/ZUI_126_DASHBOARD_BINDING_VAN.xml"
        }
      },
      "annotation": {
        "type": "ODataAnnotation",
        "uri": "annotations/annotation.xml",
        "settings": {
          "localUri": "annotations/annotation.xml"
        }
      },
      "mainService": {
        "uri": "/sap/opu/odata/sap/ZUI_126_DASHBOARD_BINDING/",
        "type": "OData",
        "settings": {
          "annotations": [
            "ZUI_126_DASHBOARD_BINDING_VAN",
            "annotation"
          ],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "2.0"
        }
      },
      "zui_126_po_demo": {
        "uri": "/sap/opu/odata4/iwbep/all/srvd/sap/zui_126_po_demo/0001/",
        "type": "OData",
        "settings": {
          "annotations": [
            "annotation0"
          ],
          "localUri": "localService/zui_126_po_demo/metadata.xml",
          "odataVersion": "4.0"
        }
      },
      "annotation0": {
        "type": "ODataAnnotation",
        "uri": "annotations/annotation0.xml",
        "settings": {
          "localUri": "annotations/annotation0.xml"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "ZSO_PO_F15000-display": {
          "semanticObject": "ZSO_PO_F15000",
           "action": "display",
          "title": "PO Dashboard"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "fullWidth": true,
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.108.33",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ushell": {},
        "sap.f": {},
        "sap.ui.comp": {},
        "sap.ui.generic.app": {},
        "sap.suite.ui.generic.template": {},
        "sap.ovp": {},
        "sap.ui.rta": {},
        "sap.ui.layout": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "zpodashboard.i18n.i18n"
        }
      },
      "mainModel": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "defaultBindingMode": "TwoWay",
          "defaultCountMode": "Inline",
          "refreshAfterChange": false,
          "metadataUrlParams": {
            "sap-value-list": "none"
          }
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      },
      "zui_126_po_demo": {
        "dataSource": "zui_126_po_demo",
        "preload": true,
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "controlId": "appContent",
        "controlAggregation": "pages",
        "async": true
      },
      "routes": [
        {
          "name": "root",
          "pattern": "",
          "target": "ovpTarget"
        },
        {
          "name": "toDetail",
          "pattern": "PurchaseOrder-display:?query:",
          "target": "detailTarget"
        }
      ],
      "targets": {
        "ovpTarget": {
          "type": "Component",
          "id": "ovpComponent",
          "name": "sap.ovp.app",
          "options": {
            "settings": {
              "encoding": "utf-8"
            }
          }
        },
        "detailTarget": {
          "type": "Component",
          "id": "detailComponent",
          "name": "sap.suite.ui.generic.template.ListReport",
          "options": {
            "settings": {
              "entitySet": "PoDashboard",
              "tableSettings": {
                "type": "ResponsiveTable"
              }
            }
          }
        }
      }
    }
  },
  "sap.ovp": {
    "globalFilterModel": "mainModel",
    "globalFilterEntitySet": "PoDashboard",
    "containerLayout": "resizable",
    "enableLiveFilter": true,
    "considerAnalyticalParameters": true,

    "cards": {
      "card01_list": {
  "model": "mainModel",
  "template": "sap.ovp.cards.list",
  "settings": {
    "title": "Purchase Order List",
    "subTitle": "PO Details",
    "entitySet": "PoDashboard",
    "listType": "extended",
    "listFlavor": "standard",
    "sortBy": "TotalAmount",
    "sortOrder": "descending",
    "annotationPath": "com.sap.vocabularies.UI.v1.LineItem",
    "identificationAnnotationPath": "com.sap.vocabularies.UI.v1.Identification",
    "navigation": "display",
    "semanticObject": "ZSO_PO_F15200",
    "action": "display"
  }
},

      "card02_chart": {
        "model": "mainModel",
        "template": "sap.ovp.cards.charts.analytical",
        "settings": {
          "title": "Top Partners",
          "entitySet": "PoDashboard",
          "chartAnnotationPath": "com.sap.vocabularies.UI.v1.Chart#ChartBySupplier",
          "presentationAnnotationPath": "com.sap.vocabularies.UI.v1.PresentationVariant#PVBySupplier",
          "identificationAnnotationPath": "com.sap.vocabularies.UI.v1.Identification",
          "semanticObject": "ZSO_PO_F15200",
          "action": "display",
          "valueSelectionInfo": "Total spend across all POs"
       
        }
      },
      "card03_timeline": {
        "model": "mainModel",
        "template": "sap.ovp.cards.charts.analytical",
        "settings": {
          "title": "Spending Analysis",
          "subTitle": "Over Time",
          "entitySet": "PoDashboard",
          "chartAnnotationPath": "com.sap.vocabularies.UI.v1.Chart#ChartByDate",
          "presentationAnnotationPath": "com.sap.vocabularies.UI.v1.PresentationVariant#PVByDate",
          "identificationAnnotationPath": "com.sap.vocabularies.UI.v1.Identification",
       "dataPointAnnotationPath": "com.sap.vocabularies.UI.v1.DataPoint#Amount"
        }
      },
      "card04_material": {
        "model": "mainModel",
        "template": "sap.ovp.cards.charts.analytical",
        "settings": {
          "title": "Goods Structure",
          "subTitle": "Top Materials",
          "entitySet": "PoDashboard",
          "chartAnnotationPath": "com.sap.vocabularies.UI.v1.Chart#ChartByMaterial",
          "presentationAnnotationPath": "com.sap.vocabularies.UI.v1.PresentationVariant#PVByMaterial",
          "identificationAnnotationPath": "com.sap.vocabularies.UI.v1.Identification"
      
        }
      },
      "card05_purchgroup": {
        "model": "mainModel",
        "template": "sap.ovp.cards.charts.analytical",
        "settings": {
          "title": "Purchasing Group",
          "subTitle": "Spend Ratio",
          "entitySet": "PoDashboard",
          "chartAnnotationPath": "com.sap.vocabularies.UI.v1.Chart#ChartByPurchGroup",
          "presentationAnnotationPath": "com.sap.vocabularies.UI.v1.PresentationVariant#PVByPurchGroup",
          "identificationAnnotationPath": "com.sap.vocabularies.UI.v1.Identification"
 
        }
      },
      "card06_user": {
        "model": "mainModel",
        "template": "sap.ovp.cards.charts.analytical",
        "settings": {
          "title": "Top Creators",
          "subTitle": "By PO Volume",
          "entitySet": "PoDashboard",
          "chartAnnotationPath": "com.sap.vocabularies.UI.v1.Chart#ChartByUser",
          "presentationAnnotationPath": "com.sap.vocabularies.UI.v1.PresentationVariant#PVByUser",
          "identificationAnnotationPath": "com.sap.vocabularies.UI.v1.Identification"
    
        }
      }
    },
    "chartSettings": {
      "showDataLabel": true
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "analytical"
  }
}

